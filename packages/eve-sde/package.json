{
  "name": "@eve-online-tools/eve-sde",
  "version": "0.1.0",
  "description": "EVE Online Static Data Export loader with Vite and Rollup plugins",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eve-online-tools/node-packages.git",
    "directory": "packages/eve-sde"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite/index.js"
      },
      "require": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite/index.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup/index.d.ts",
        "default": "./dist/rollup/index.js"
      },
      "require": {
        "types": "./dist/rollup/index.d.ts",
        "default": "./dist/rollup/index.cjs"
      }
    },
    "./processors": {
      "import": {
        "types": "./dist/processors/index.d.ts",
        "default": "./dist/processors/index.js"
      },
      "require": {
        "types": "./dist/processors/index.d.ts",
        "default": "./dist/processors/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/processors/index.ts src/vite/index.ts src/rollup/index.ts --format cjs,esm --dts --clean --external vite --external rollup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --workspace-root vitest run packages/eve-sde",
    "format:check": "pnpm --workspace-root exec oxfmt --check \"packages/eve-sde/src/**/*.ts\"",
    "oxlint": "pnpm --workspace-root exec oxlint packages/eve-sde"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "peerDependencies": {
    "rollup": "^4.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rollup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
