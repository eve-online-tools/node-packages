{
  "name": "node-packages-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eve-online-tools/node-packages.git"
  },
  "scripts": {
    "build": "turbo build",
    "clean": "tsx scripts/clean.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "create-package": "tsx scripts/create-package.ts",
    "dev:demo": "turbo dev --filter=@eve-online-tools/demo",
    "storybook": "turbo dev --filter=@eve-online-tools/storybook",
    "typecheck": "turbo typecheck && tsc --noEmit -p tsconfig.tools.json",
    "format": "pnpm format:write",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\"",
    "oxlint": "oxlint .",
    "stylelint": "stylelint '**/*.css' --cache --allow-empty-input",
    "syncpack": "syncpack list-mismatches",
    "syncpack:format": "syncpack format",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test": "pnpm syncpack && pnpm format:check && pnpm typecheck && pnpm oxlint && pnpm stylelint && turbo test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@mantine-tests/core": "^2.0.0",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@rollup/plugin-node-resolve": "catalog:",
    "@rollup/plugin-replace": "catalog:",
    "@storybook/addon-essentials": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/identity-obj-proxy": "^3",
    "@types/node": "catalog:",
    "@types/postcss-import": "^14.0.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/signale": "^1",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "catalog:",
    "hash-css-selector": "^1.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "catalog:",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "postcss": "catalog:",
    "postcss-import": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "^6.0.1",
    "rollup": "catalog:",
    "rollup-plugin-banner2": "catalog:",
    "rollup-plugin-esbuild": "catalog:",
    "rollup-plugin-node-externals": "catalog:",
    "rollup-plugin-postcss": "catalog:",
    "signale": "^1.4.0",
    "storybook": "catalog:",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "syncpack": "^15.3.2",
    "tsup": "catalog:",
    "tsx": "^4.19.4",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
